	partition calendar = m
		mode: import
		source =
				// Power Query (M)
				// Load the "calendar" entity from a specific Power Platform Dataflow
				
				let
				    // 1) Connect to Power Platform Dataflows.
				    //    'null' = use default environment context.
				    Source = PowerPlatform.Dataflows(null),
				
				    // 2) Extract the top-level Workspaces table.
				    //    This contains all accessible Power BI/Power Platform workspaces.
				    Workspaces = Source{[Id = "Workspaces"]}[Data],
				
				    // 3) Select a specific workspace by its workspaceId (GUID) and get its Data table.
				    Workspace_Selected =
				        Workspaces{[workspaceId = "3ba57f0e-47dc-4868-8b0e-88d61d5e442c"]}[Data],
				
				    // 4) Inside that workspace, select a dataflow by its dataflowId (GUID).
				    Dataflow_Selected =
				        Workspace_Selected{[dataflowId = "32720a24-761e-4883-abc6-61e2ee994765"]}[Data],
				
				    // 5) From the selected dataflow, load the "calendar" entity.
				    //    version = "" typically means the default (latest) version.
				    Calendar_Entity =
				        Dataflow_Selected{[entity = "calendar", version = ""]}[Data]
				
				in
				    // 6) Output final table
				    Calendar_Entity

	changedProperty = Name

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

