	partition financials = m
		mode: import
		source =
				// Power Query (M)
				// Load the "financials" entity from a specific Power Platform Dataflow
				
				let
				    // 1) Connect to the Power Platform Dataflows connector.
				    //    'null' means using the default environment context.
				    Source = PowerPlatform.Dataflows(null),
				
				    // 2) From the connector output, extract the "Workspaces" table.
				    //    It contains all workspaces accessible to the signed‑in user.
				    Workspaces = Source{[Id = "Workspaces"]}[Data],
				
				    // 3) Select a workspace by its GUID (workspaceId) and extract its Data table.
				    Workspace_Selected =
				        Workspaces{[workspaceId = "3ba57f0e-47dc-4868-8b0e-88d61d5e442c"]}[Data],
				
				    // 4) Inside this workspace, select the desired Dataflow by its dataflowId.
				    Dataflow_Selected =
				        Workspace_Selected{[dataflowId = "32720a24-761e-4883-abc6-61e2ee994765"]}[Data],
				
				    // 5) From the Dataflow, load the entity named "financials".
				    //    version = "" usually returns the default (most recent) version.
				    Financials_Entity =
				        Dataflow_Selected{[entity = "financials", version = ""]}[Data]
				
				in
				    // 6) Output the final entity as a table
				    Financials_Entity

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

